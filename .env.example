# ════════════════════════════════════════════════════════════════════════════
# WaSphere — environment for docker-compose.yml (the full self-hosted stack)
#
#   cp .env.example .env
#   # fill in the secrets below, then:
#   docker compose up -d
#   # open http://localhost:3004
#
# Generate every secret with:  openssl rand -hex 32
# ════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=wasphere
POSTGRES_PASSWORD=change_me_strong_db_password
POSTGRES_DB=wasphere

# ── Secrets (REQUIRED — generate each separately with `openssl rand -hex 32`) ──
# Auth secret for dashboard JWTs (min 32 chars)
JWT_SECRET=change_me_openssl_rand_hex_32

# 32-byte hex key (exactly 64 hex chars) encrypting stored WA Server tokens
ENCRYPTION_KEY=change_me_openssl_rand_hex_32

# WA Server API token — how you authenticate to the WhatsApp gateway (min 16)
WA_TOKEN=change_me_openssl_rand_hex_32

# HMAC secret signing OUTBOUND webhooks delivered to your endpoints
WEBHOOK_SIGNING_SECRET=change_me_openssl_rand_hex_32

# Shared secret for internal wa-server <-> dashboard-api traffic.
# Must be identical for both — they're in one .env, so this one value covers both.
INTERNAL_WEBHOOK_SECRET=change_me_openssl_rand_hex_32

# ── URLs / ports (optional — sensible defaults for localhost) ─────────────────
# Public URL the browser uses to reach the dashboard. Used for CORS.
# Change to https://app.your-domain.com when behind a reverse proxy.
DASHBOARD_UI_URL=http://localhost:3004

# Host ports (override only if 3000/3001/3004 clash with something else)
# DASHBOARD_UI_PORT=3004
# DASHBOARD_API_PORT=3000
# WA_SERVER_PORT=3001

# Leave DASHBOARD_WEBHOOK_URL UNSET — the dashboard registers it automatically.
# Setting it manually causes a self-referential webhook loop.

# ── Meta WhatsApp Cloud API provider (optional — ships DISABLED) ───────────────
# Set to true to run sessions on the official Meta Cloud API alongside Baileys.
# Leave false (default) if you only use Baileys QR sessions.
# META_PROVIDER_ENABLED=false
# Graph API version for Cloud API calls (bump on Meta's ~6-month cadence).
# GRAPH_VERSION=v22.0
# Public URL of the WA Server (e.g. https://wa.your-domain.com). Only used to
# auto-fill the Meta webhook callback URL in the dashboard's New-Session dialog.
# WA_SERVER_PUBLIC_URL=https://wa.your-domain.com
