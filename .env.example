# ── WA Server ────────────────────────────────────────────────────────────────
# Secret token required to authenticate all API requests to wa-server.
# Minimum 16 characters. Accepted via X-Api-Token header only.
WA_TOKEN=change_me_at_least_16_chars

# Port wa-server listens on. Default: 3001.
PORT=3001

# CORS origin for the dashboard. Must be a specific URL, not wildcard.
CORS_ORIGIN=http://localhost:3000

# ── Dashboard API (Phase 3+) ─────────────────────────────────────────────────
# PostgreSQL 16 connection string.
# Local dev default matches docker-compose.yml values.
DATABASE_URL=postgresql://wasphere:wasphere_dev@localhost:5432/wasphere

# Audit log retention in days. Rows older than this are deleted by the
# scheduled purge job in dashboard-api. Default: 90.
AUDIT_RETENTION_DAYS=90
