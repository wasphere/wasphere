{
  "name": "@wasphere/dashboard-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "postinstall": "prisma generate",
    "test:setup": "docker exec wasphere-postgres psql -U wasphere -tc \"SELECT 1 FROM pg_database WHERE datname='wasphere_test'\" | grep -q 1 || docker exec wasphere-postgres createdb -U wasphere wasphere_test; DATABASE_URL=postgresql://wasphere:wasphere_dev@localhost:5432/wasphere_test npx prisma migrate deploy",
    "test": "pnpm build && node --test --test-concurrency=1 test/inbox-ingest.test.js test/inbox-service.test.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "8.1.1",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^6.9.0",
    "@scalar/nestjs-api-reference": "^1.1.19",
    "argon2": "^0.31.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "ipaddr.js": "^2.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
