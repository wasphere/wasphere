generator client {
  provider = "prisma-client-js"
  // Generate into the package's own node_modules so `pnpm deploy --prod` bundles
  // the client into the runtime image. Requires a flat (hoisted) node_modules so
  // @prisma/client resolves this path — enforced by the repo-root .npmrc.
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// audit_logs — written by dashboard-api when wa-server POSTs audit events.
// Phase 2 model. DO NOT MODIFY — the Phase 2 migration is already applied.
// ---------------------------------------------------------------------------
model AuditLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp        DateTime @default(now()) @db.Timestamptz()
  sessionId        String?  @map("session_id")
  actorTokenPrefix String?  @map("actor_token_prefix")
  method           String
  endpoint         String
  statusCode       Int?     @map("status_code")
  requestHash      String?  @map("request_hash")
  ipAddress        String?  @map("ip_address")

  @@index([timestamp(sort: Desc)])
  @@index([sessionId, timestamp(sort: Desc)])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// users
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  workspaces          WorkspaceMember[]
  ownedWorkspaces     Workspace[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdApiKeys      ApiKey[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// workspaces
// ---------------------------------------------------------------------------
model Workspace {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  ownerId         String   @map("owner_id") @db.Uuid
  waServerUrl     String?  @map("wa_server_url")
  // AES-256-GCM ciphertext, hex-encoded. Null until wa-server is registered.
  waServerToken   String?  @map("wa_server_token")
  // 12-byte IV, hex-encoded. Always stored alongside the ciphertext.
  waServerTokenIv String?  @map("wa_server_token_iv")
  // Optional custom logo (data: URI) for dashboard branding. Null = default logo.
  logo            String?  @db.Text @map("logo")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  owner         User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  customRoles   CustomRole[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  // Inbox (v1.1) — virtual back-relations, no DB columns added to workspaces
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]

  @@index([ownerId])
  @@map("workspaces")
}

// ---------------------------------------------------------------------------
// workspace_members — join table for user <-> workspace many-to-many
// ---------------------------------------------------------------------------
model WorkspaceMember {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  // Authority tier. OWNER/ADMIN have full access; MEMBER's capabilities come
  // from the assigned custom role (see customRole).
  role        WorkspaceRole @default(MEMBER)
  // For MEMBER tier: the custom role defining this agent's capabilities.
  // Null = defaults only (inbox/contacts). Ignored for OWNER/ADMIN.
  customRoleId String?      @map("custom_role_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([customRoleId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

// Named, reusable permission sets an owner defines for agents (MEMBER tier).
// e.g. "Support" = inbox+contacts, "Developer" = api_keys+webhooks.
model CustomRole {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  name         String
  // Array of capability strings (see src/lib/capabilities.ts).
  capabilities Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]
  invites   WorkspaceInvite[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("custom_roles")
}

// Pending invitations to join a workspace (invite-link flow; no email needed).
model WorkspaceInvite {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  // SHA-256 of the invite token; the raw token only ever lives in the link.
  tokenHash   String        @unique @map("token_hash")
  // Authority tier the invitee joins as.
  role        WorkspaceRole @default(MEMBER)
  // For MEMBER-tier invites: the custom role assigned on acceptance.
  customRoleId String?      @map("custom_role_id") @db.Uuid
  createdBy   String        @map("created_by") @db.Uuid
  expiresAt   DateTime      @map("expires_at") @db.Timestamptz()
  acceptedAt  DateTime?     @map("accepted_at") @db.Timestamptz()
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@map("workspace_invites")
}

// ---------------------------------------------------------------------------
// refresh_tokens — stored per user; allows individual token revocation
// ---------------------------------------------------------------------------
model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  // SHA-256 of the raw opaque token string. Never store the raw token.
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// api_keys — dashboard API keys with permission scopes and optional session scope
// ---------------------------------------------------------------------------
model ApiKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  // First 12 chars of the raw key (e.g. "wsk_aB3kF9Pq") — safe to display
  keyPrefix   String    @unique @map("key_prefix")
  // argon2id hash of the full key. Never expose.
  keyHash     String    @map("key_hash")
  // Array of permission scope strings (e.g. ["messages:send","sessions:read"]) or ["*"] for wildcard
  permissions Json      @default("[]")
  // NULL = all sessions in workspace; non-null = scoped to this session id
  sessionId   String?   @map("session_id")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz()
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz()
  createdById String?   @map("created_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([keyPrefix])
  @@index([workspaceId, isActive])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// webhooks — per-workspace webhook endpoints with event filtering
// ---------------------------------------------------------------------------
model Webhook {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  name            String
  url             String
  // Array of event type strings (e.g. ["message.sent","session.connected"]) or ["*"] for all
  events          Json      @default("[]")
  // HMAC-SHA256 signing secret, 64 hex chars. Never expose in list endpoints.
  signingSecret   String    @map("signing_secret")
  isActive        Boolean   @default(true) @map("is_active")
  retryMax        Int       @default(3) @map("retry_max")
  // Consecutive failures; auto-deactivate at 50
  failureCount    Int       @default(0) @map("failure_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastDeliveredAt DateTime? @map("last_delivered_at") @db.Timestamptz()
  lastFailedAt    DateTime? @map("last_failed_at") @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@map("webhooks")
}

// ---------------------------------------------------------------------------
// password_reset_tokens
// ---------------------------------------------------------------------------
model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  // SHA-256 of the raw reset token. Never store the raw token.
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// ===========================================================================
// Inbox (v1.1 — "Receive & Observe").
// Net-new, greenfield tables. Ingestion + REST + SSE land in later commits.
// ===========================================================================

enum ConversationStatus {
  OPEN
  RESOLVED
  SNOOZED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ---------------------------------------------------------------------------
// contacts — one row per (workspace, WhatsApp JID).
// Name resolution priority: savedName ?? whatsappName ?? phone.
// ---------------------------------------------------------------------------
model Contact {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  // WhatsApp JID, e.g. 447700900123@s.whatsapp.net
  jid          String
  // normalized digits, e.g. 447700900123
  phone        String
  // auto-updated from WhatsApp pushName on each inbound
  whatsappName String?  @map("whatsapp_name")
  // operator-set; NEVER auto-overwritten
  savedName    String?  @map("saved_name")
  avatarUrl    String?  @map("avatar_url")
  // CRM labels for segmenting contacts (e.g. Lead, Customer, VIP)
  tags         String[] @default([])
  // Free-form operator note about this contact
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([workspaceId, jid])
  @@index([workspaceId, phone])
  @@map("contacts")
}

// ---------------------------------------------------------------------------
// conversations — one thread per (workspace, session, contact).
// ---------------------------------------------------------------------------
model Conversation {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String             @map("workspace_id") @db.Uuid
  contactId        String             @map("contact_id") @db.Uuid
  // which WA session/number owns this thread
  sessionId        String             @map("session_id")
  status           ConversationStatus @default(OPEN)
  lastMessageAt    DateTime           @default(now()) @map("last_message_at") @db.Timestamptz()
  // denormalized snippet for the list view
  lastPreview      String?            @map("last_preview")
  unreadCount      Int                @default(0) @map("unread_count")
  // JSON array of tag strings (matches the api_keys/webhooks Json-array convention)
  tags             Json               @default("[]")
  // set when the owning WA session is deleted -> read-only archive
  sessionDeletedAt DateTime?          @map("session_deleted_at") @db.Timestamptz()
  metadata         Json?
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([workspaceId, sessionId, contactId])
  @@index([workspaceId, status, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

// ---------------------------------------------------------------------------
// messages — persisted inbound + outbound. Idempotent on (workspace, waMessageId).
// Full-text search index (pg_trgm) is added in a later commit.
// ---------------------------------------------------------------------------
model Message {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String                @map("workspace_id") @db.Uuid
  conversationId String                @map("conversation_id") @db.Uuid
  // Baileys message key id
  waMessageId    String                @map("wa_message_id")
  direction      MessageDirection
  // text | image | video | audio | document | sticker | location | contact | poll | reaction
  type           String
  // text body / media caption
  body           String?
  // resolved media download URL (media handling lands in a later commit)
  mediaUrl       String?               @map("media_url")
  // sanitized type-specific data (poll options/results, location, contact card, quoted ref)
  payload        Json?
  status         MessageDeliveryStatus @default(SENT)
  fromMe         Boolean               @map("from_me")
  // WhatsApp's own message timestamp
  waTimestamp    DateTime              @map("wa_timestamp") @db.Timestamptz()
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz()

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, waMessageId])
  @@index([conversationId, waTimestamp(sort: Desc)])
  @@map("messages")
}
