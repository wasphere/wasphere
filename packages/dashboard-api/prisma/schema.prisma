generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// audit_logs — written by dashboard-api when wa-server POSTs audit events.
// Phase 2 model. DO NOT MODIFY — the Phase 2 migration is already applied.
// ---------------------------------------------------------------------------
model AuditLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp        DateTime @default(now()) @db.Timestamptz()
  sessionId        String?  @map("session_id")
  actorTokenPrefix String?  @map("actor_token_prefix")
  method           String
  endpoint         String
  statusCode       Int?     @map("status_code")
  requestHash      String?  @map("request_hash")
  ipAddress        String?  @map("ip_address")

  @@index([timestamp(sort: Desc)])
  @@index([sessionId, timestamp(sort: Desc)])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// users
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  workspaces          WorkspaceMember[]
  ownedWorkspaces     Workspace[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdApiKeys      ApiKey[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// workspaces
// ---------------------------------------------------------------------------
model Workspace {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  ownerId         String   @map("owner_id") @db.Uuid
  waServerUrl     String?  @map("wa_server_url")
  // AES-256-GCM ciphertext, hex-encoded. Null until wa-server is registered.
  waServerToken   String?  @map("wa_server_token")
  // 12-byte IV, hex-encoded. Always stored alongside the ciphertext.
  waServerTokenIv String?  @map("wa_server_token_iv")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  owner   User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  apiKeys ApiKey[]
  webhooks Webhook[]

  @@index([ownerId])
  @@map("workspaces")
}

// ---------------------------------------------------------------------------
// workspace_members — join table for user <-> workspace many-to-many
// ---------------------------------------------------------------------------
model WorkspaceMember {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

// ---------------------------------------------------------------------------
// refresh_tokens — stored per user; allows individual token revocation
// ---------------------------------------------------------------------------
model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  // SHA-256 of the raw opaque token string. Never store the raw token.
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// api_keys — dashboard API keys with permission scopes and optional session scope
// ---------------------------------------------------------------------------
model ApiKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  // First 12 chars of the raw key (e.g. "wsk_aB3kF9Pq") — safe to display
  keyPrefix   String    @unique @map("key_prefix")
  // argon2id hash of the full key. Never expose.
  keyHash     String    @map("key_hash")
  // Array of permission scope strings (e.g. ["messages:send","sessions:read"]) or ["*"] for wildcard
  permissions Json      @default("[]")
  // NULL = all sessions in workspace; non-null = scoped to this session id
  sessionId   String?   @map("session_id")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz()
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz()
  createdById String?   @map("created_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([keyPrefix])
  @@index([workspaceId, isActive])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// webhooks — per-workspace webhook endpoints with event filtering
// ---------------------------------------------------------------------------
model Webhook {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  name            String
  url             String
  // Array of event type strings (e.g. ["message.sent","session.connected"]) or ["*"] for all
  events          Json      @default("[]")
  // HMAC-SHA256 signing secret, 64 hex chars. Never expose in list endpoints.
  signingSecret   String    @map("signing_secret")
  isActive        Boolean   @default(true) @map("is_active")
  retryMax        Int       @default(3) @map("retry_max")
  // Consecutive failures; auto-deactivate at 50
  failureCount    Int       @default(0) @map("failure_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastDeliveredAt DateTime? @map("last_delivered_at") @db.Timestamptz()
  lastFailedAt    DateTime? @map("last_failed_at") @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@map("webhooks")
}

// ---------------------------------------------------------------------------
// password_reset_tokens
// ---------------------------------------------------------------------------
model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  // SHA-256 of the raw reset token. Never store the raw token.
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_reset_tokens")
}
