# WaSphere WA Server — example environment file
# Copy this to .env and fill in real values: cp .env.example .env

# REQUIRED — secret token for API authentication (min 16 chars)
# Generate with: openssl rand -hex 48
WA_TOKEN=

# Port the server listens on
PORT=3001

# CORS allowed origin — set to your dashboard URL in production
# Leave as http://localhost:3000 for local dev
# Wildcard '*' is blocked by the CORS_ORIGIN guard
CORS_ORIGIN=http://localhost:3000

# Dashboard callback URL — set automatically by the dashboard during workspace setup.
# Do NOT set this manually — it causes a self-referential webhook loop.
# Leave empty; the dashboard will configure it on first connection.
DASHBOARD_WEBHOOK_URL=
WEBHOOK_SIGNING_SECRET=
INTERNAL_WEBHOOK_SECRET=

# ─── Meta WhatsApp Cloud API provider (v1.2 · opt-in) ───
# Enables the official Meta Cloud API provider alongside Baileys. Ships DISABLED —
# existing Baileys sessions are unaffected. Set to "true" to opt in once a Meta
# session is configured. (Until then this provider is dormant.)
META_PROVIDER_ENABLED=false

# Meta Graph API version for Cloud API calls. Bump on Meta's ~6-month deprecation
# cadence. Default: v22.0
GRAPH_VERSION=v22.0
