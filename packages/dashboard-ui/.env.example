# WaSphere Dashboard UI — example environment file
# Copy to .env and adjust for your deployment: cp .env.example .env

# Base URL of the Dashboard API (NestJS) the UI talks to, server-side.
# Docker:  http://dashboard-api:3000   (compose service name)
# Manual:  http://localhost:3000
DASHBOARD_API_URL=http://localhost:3000

# Internal URL the dashboard uses to reach the WA Server (WhatsApp backend).
# This is also the default suggested in Settings → WA Server.
# Docker:       http://wa-server:3001   (compose service name)
# Manual:       http://localhost:3001   (or your host IP:port)
# Kubernetes:   http://wa-server.<namespace>.svc.cluster.local:3001
WA_SERVER_INTERNAL_URL=http://localhost:3001

# production enables secure cookies and HTTPS-only behaviour
NODE_ENV=development
