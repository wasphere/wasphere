{
  "name": "wasphere",
  "version": "1.0.0",
  "private": true,
  "description": "WaSphere — open-source WhatsApp automation platform",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wasphere/wasphere"
  },
  "bugs": "https://github.com/wasphere/wasphere/issues",
  "homepage": "https://wasphere.com",
  "keywords": ["whatsapp", "api", "self-hosted", "baileys", "mit"],
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' dev",
    "build": "pnpm --recursive --filter './packages/*' build",
    "prisma:migrate": "pnpm --filter @wasphere/dashboard-api prisma:migrate",
    "wa-server:dev": "pnpm --filter @wasphere/wa-server dev"
  },
  "workspaces": [
    "packages/*"
  ]
}
